{
    "manifest_version": 3,
    "name": "WaifuEverywhere",
    "version": "2.0.0",
    "description": "Firefox add-on to get waifu images.",
    "developer": {
        "name": "Gregorio P.",
        "url": "https://github.com/TecnoCreeper/WaifuEverywhere"
    },
    "icons": {
        "32": "icons/icon_32.png",
        "64": "icons/icon_64.png",
        "128": "icons/icon_128.png"
    },
    "action": {
        "default_icon": {
            "32": "icons/icon_32.png",
            "64": "icons/icon_64.png",
            "128": "icons/icon_128.png"
        },
        "default_title": "WaifuEverywhere",
        "default_popup": "popup/waifu.html"
    },
    "permissions": ["storage"],
    "browser_specific_settings": {
        "gecko": {
            "id": "{4516a1cf-8576-45fb-8eb9-e693cb66718a}",
            "data_collection_permissions": {
                "required": ["none"]
            }
        }
    }
}
